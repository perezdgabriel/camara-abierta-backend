# Copy to ``.env`` (committed defaults) or ``.env.local`` (your secrets, gitignored).
# Both files are loaded; ``.env.local`` wins on conflict.
# All values shown here are the application defaults — uncomment + edit to override.

# ── Core ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres@localhost:5432/camara_abierta"
TEST_DATABASE_URL="postgresql://postgres@localhost:5432/camara_abierta_test"
REDIS_URL="redis://localhost:6379/0"
# CORS_ORIGINS='["http://localhost:3000"]'

# ── Admin panel ───────────────────────────────────────────────────────
ADMIN_SECRET_KEY="change-me-in-production"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin"

# ── Bills AI summary (Anthropic Claude — ADR-0019) ────────────────────
# Off by default so a fresh `ingestors bills` scan never silently burns
# LLM budget. Flip to ``true`` per environment when ready to pay; applies
# to both the auto-enqueue in sync_bill and the `ai bills regenerate` CLI.
AI_SUMMARY_ENABLED=false
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5"
AI_SUMMARY_PROMPT_VERSION="v2"

# ── Norms AI enrichment (Diario Oficial — Gemini primary, OpenWebUI fallback) ─
# Independent from bills; the norms pipeline keeps the two-provider setup.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENWEBUI_URL="http://localhost:3000"
OPENWEBUI_API_KEY=""
OPENWEBUI_MODEL="llama3"
FILE_PROCESS_TIMEOUT=120

# ── Notifications (Resend) ────────────────────────────────────────────
RESEND_API_KEY=""
# NOTIFICATION_EMAIL=""
NOTIFICATION_FROM_EMAIL="noreply@camaraabierta.cl"

# ── Ingestor base URLs ────────────────────────────────────────────────
INGESTOR_BASE_URL_CAMARA="https://opendata.congreso.cl/wscamaradiputados.asmx/"
INGESTOR_BASE_URL_OPENDATA_CAMARA="https://opendata.camara.cl/camaradiputados/WServices/"
INGESTOR_BASE_URL_SENADO="https://tramitacion.senado.cl/wspublico/"
INGESTOR_BASE_URL_SENADO_WEB="https://web-back.senado.cl/"
INGESTOR_BASE_URL_BCN="https://datos.bcn.cl/"
INGESTOR_BASE_URL_RESTSIL="https://restsil.senado.cl/v3/"

# ── Ingestor sources + tuning ─────────────────────────────────────────
# Required for restsil (ADR-0013): the apikey-authed bills + Senate-votes feed.
INGESTOR_RESTSIL_API_KEY=""

# Discovery / failover switches (defaults match ADR-0013 production setup).
INGESTOR_BILLS_SOURCE="restsil"            # restsil | opendata
INGESTOR_SENATE_VOTES_SOURCE="restsil"     # restsil | wspublico
INGESTOR_CHAMBER_VOTES_SOURCE="bulk"       # bulk    | bill_detail
INGESTOR_BILL_DETAIL_SOURCE="restsil"      # restsil | wspublico

# Backfill horizon + paging caps.
INGESTOR_BILLS_START_YEAR=1990
INGESTOR_OPENDATA_ASYNC_CONCURRENCY=10
INGESTOR_CHAMBER_VOTES_MAX_YEARS_PER_TICK=10
INGESTOR_RESTSIL_PAGE_SIZE=100
INGESTOR_RESTSIL_MAX_PAGES_PER_TICK=100
INGESTOR_RESTSIL_ASYNC_CONCURRENCY=10
